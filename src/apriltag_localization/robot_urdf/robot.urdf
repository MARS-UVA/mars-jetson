<?xml version="1.0"?>
<robot name="MARS-2026-robot">

  <material name="blue">
    <color rgba="0.0 0.2 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5588 0.4572 0.0254"/> 
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.5588 0.4572 0.0254"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.087" ixy="0.0" ixz="0.0" iyy="0.130" iyz="0.0" izz="0.217"/>
    </inertial>
  </link>

  <link name="front_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
    </collision>
  </link>

  <link name="front_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
    </collision>
  </link>

  <link name="rear_right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1397" length="0.1016"/>
      </geometry>
    </collision>
  </link>

  <joint name="fl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin xyz="0.2413 0.2794 0.0381" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="fr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin xyz="0.2413 -0.2794 0.0381" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rl_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin xyz="-0.2413 0.2794 0.0381" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="rr_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel"/>
    <origin xyz="-0.2413 -0.2794 0.0381" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="camera_long_left">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.04"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>
  <joint name="cam_long_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_long_left"/>
    <origin xyz="0 0.2586 0.0327" rpy="0 0 0"/>
  </joint>

  <link name="camera_long_right">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.04"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>
  <joint name="cam_long_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_long_right"/>
    <origin xyz="0 -0.2586 0.0327" rpy="0 0 0"/>
  </joint>

  <link name="camera_short_front">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>
  <joint name="cam_short_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_short_front"/>
    <origin xyz="0.3094 0.1524 0.0327" rpy="0 0 0"/>
  </joint>

  <link name="camera_short_rear">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.04 0.04"/>
      </geometry>
      <material name="green"/>
    </visual>
  </link>
  <joint name="cam_short_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_short_rear"/>
    <origin xyz="-0.3094 -0.1524 0.0327" rpy="0 0 0"/>
  </joint>

</robot>